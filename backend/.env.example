# Required: Groq API key — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Optional: Tavily API key for live web search fallback — https://tavily.com
# When absent, the Research agent uses mock data only.
TAVILY_API_KEY=

# Optional model overrides
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: Postgres URL for persistent conversation memory.
# When set, LangGraph's PostgresSaver replaces MemorySaver and threads
# survive backend restarts. Works with any Postgres — Supabase, Neon,
# Railway Postgres, RDS, self-hosted.
#
# Supabase setup:
#   1. https://app.supabase.com → New Project (free tier is plenty)
#   2. Project Settings → Database → "Connection string" → URI tab
#   3. Use the *Session Pooler* (port 5432) or *Direct Connection*.
#      Do NOT use Transaction Pooler (6543) — it breaks prepared
#      statements that LangGraph relies on.
#   4. Replace [YOUR-PASSWORD] in the URI with the DB password you set.
#
# Example:
# DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres
DATABASE_URL=
